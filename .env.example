# =============================================================================
# p9i - LLM Providers Configuration
# =============================================================================
# This file contains all environment variables for configuring LLM providers.
# Copy this file to .env and fill in your API keys.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your API keys
#
# Provider Priority (auto-detected):
#   1. MiniMax (best price/performance) - PRIMARY
#   2. Z.ai / GLM (best quality)
#   3. OpenRouter (free via OpenRouter)
#   4. DeepSeek (reasoning)
#   5. Anthropic (requires explicit CLAUDE.md permission)
# =============================================================================

# === Primary Provider Selection ===
# Explicitly set provider (optional - auto-detected if not set)
# Options: auto, minimax, glm-4-7, glm-4-5-air, zai-claude, deepseek, deepseek-reasoner, anthropic, hunter
LLM_PROVIDER=auto


# =============================================================================
# MiniMax Configuration (Primary - Best Price/Performance)
# =============================================================================
# Documentation: https://platform.minimax.io
# API Key: Get from https://platform.minimax.io/account/api-keys

MINIMAX_API_KEY=
MINIMAX_ENABLED=true
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TEMPERATURE=0.7
MINIMAX_MAX_TOKENS=4096


# =============================================================================
# Z.ai Configuration (GLM Models - Best Quality)
# =============================================================================
# Documentation: https://docs.z.ai
# API Key: Get from https://z.ai/dashboard/keys

ZAI_API_KEY=
ZAI_ENABLED=true
ZAI_MODEL=GLM-4.7
ZAI_TEMPERATURE=0.7
ZAI_MAX_TOKENS=4096


# =============================================================================
# DeepSeek Configuration
# =============================================================================
# Documentation: https://api-docs.deepseek.com
# API Key: Get from https://platform.deepseek.com/api-keys

DEEPSEEK_API_KEY=
DEEPSEEK_ENABLED=true
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=4096


# =============================================================================
# OpenRouter Configuration (Free Models)
# =============================================================================
# Documentation: https://openrouter.ai/docs
# API Key: Get from https://openrouter.ai/settings

OPENROUTER_API_KEY=
OPENROUTER_ENABLED=true
OPENROUTER_MODEL=anthropic/claude-3-haiku
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=4096


# =============================================================================
# Anthropic Direct Configuration
# =============================================================================
# Documentation: https://docs.anthropic.com
# API Key: Get from https://console.anthropic.com/settings/keys
# WARNING: Requires explicit permission in CLAUDE.md

ANTHROPIC_API_KEY=
ANTHROPIC_ENABLED=false
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=4096


# =============================================================================
# Fallback & Retry Configuration
# =============================================================================
# Enable automatic failover when provider fails
LLM_FAILOVER_ENABLED=true

# Custom fallback chain (comma-separated provider names)
# Default: minimax,glm-4-7,hunter,deepseek,anthropic
LLM_FAILOVER_ORDER=minimax,glm-4-7,hunter,deepseek,anthropic

# Retry configuration
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0
LLM_TIMEOUT=120


# =============================================================================
# Server Configuration
# =============================================================================
# MCP transport mode: stdio (for Claude Code) or sse (for HTTP)
MCP_TRANSPORT=stdio

# Server port (for SSE transport)
SERVER_PORT=8000

# Logging
LOG_LEVEL=INFO


# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL (for persistent data)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=p9i
POSTGRES_USER=p9i
POSTGRES_PASSWORD=

# Redis (for cache, sessions, rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# =============================================================================
# JWT Authentication (Optional)
# =============================================================================
# Secret key for JWT token generation (use JWT_SECRET, not JWT_SECRET_KEY)
JWT_SECRET=your-secret-key-here

# JWT admin key (required for generating admin tokens)
JWT_ADMIN_KEY=

# Enable/disable JWT authentication
JWT_ENABLED=true

# Token expiration (hours)
JWT_EXPIRY_HOURS=24


# =============================================================================
# Project Adaptation
# =============================================================================
# Root directory for project access (used by adapt_to_project)
PROJECT_ROOT=/project


# =============================================================================
# Rate Limiting
# =============================================================================
# Requests per minute per API key
RATE_LIMIT_REQUESTS=60


# =============================================================================
# Additional Services (p9i specific)
# =============================================================================
# Domain & External IP
DOMAIN=coderweb.ru
EXTERNAL_IP=144.31.76.95

# AIHUBMIX (universal key for multiple models)
AIHUBMIX_API_KEY=

# Context7 (MCP server)
CONTEXT7_API_KEY=

# GitHub MCP
GITHUB_TOKEN=
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# Figma
FIGMA_TOKEN=
